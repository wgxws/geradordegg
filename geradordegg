        '550209': { bank:'Mastercard', brand:'MASTERCARD', level:'STANDARD', country:'GBR', type:'CREDIT' },
        '411111': { bank:'Visa Test', brand:'VISA', level:'CLASSIC', country:'USA', type:'CREDIT' },
        '510510': { bank:'Mastercard Test', brand:'MASTERCARD', level:'STANDARD', country:'USA', type:'CREDIT' },
        '371449': { bank:'American Express', brand:'AMEX', level:'GOLD', country:'USA', type:'CREDIT' },
        '515462': { bank:'Mastercard', brand:'MASTERCARD', level:'STANDARD', country:'USA', type:'CREDIT' }
        // NENHUM BIN INVENTADO AQUI
    };
    return map[prefix] || null;
}

// ============================================================
//  ALGORITMO DE LUHN (validaรยงรยฃo de cartรยฃo)
// ============================================================
function luhnCheck(cardNumber) {
    const digits = cardNumber.split('').map(Number);
    let sum = 0, isEven = false;
    for (let i = digits.length - 1; i >= 0; i--) {
        let digit = digits[i];
        if (isEven) { digit *= 2; if (digit > 9) digit -= 9; }
        sum += digit;
        isEven = !isEven;
    }
    return sum % 10 === 0;
}

// ============================================================
//  GERAR NรลกMERO DE CARTรฦO VรยLIDO (com Luhn)
// ============================================================
function generateValidCard(binStart) {
    // Substitui 'x' por dรยญgitos aleatรยณrios
    let processed = binStart.replace(/x/gi, () => Math.floor(Math.random()*10));
    const cardLength = (processed.startsWith('34') || processed.startsWith('37')) ? 15 : 16;

    while (true) {
        let cardNumber = processed;
        while (cardNumber.length < cardLength) {
            cardNumber += Math.floor(Math.random()*10);
        }
        if (cardNumber.length === cardLength && luhnCheck(cardNumber)) {
            return cardNumber;
        }
        // Se passou do tamanho ou invรยกlido, tenta ajustar o รยบltimo dรยญgito
        if (cardNumber.length === cardLength) {
            for (let last=0; last<10; last++) {
                const test = cardNumber.substring(0, cardLength-1) + last;
                if (luhnCheck(test)) return test;
            }
        }
    }
}

// ============================================================
//  GERAR CARTรฦO COMPLETO (nรยบmero, mรยชs, ano, cvv)
// ============================================================
function generateCompleteCard(bin, fixedMonth, fixedYear, fixedCvv) {
    const number = generateValidCard(bin);
    let month, year;

    if (fixedMonth && fixedYear) {
        month = String(fixedMonth).padStart(2,'0');
        year = fixedYear;
    } else {
        month = String(Math.floor(Math.random()*12)+1).padStart(2,'0');
        year = String(Math.floor(Math.random() * (2040-2026+1)) + 2026);
    }

    const isAmex = bin.startsWith('34') || bin.startsWith('37');
    let cvv;
    if (fixedCvv !== null && fixedCvv !== '') {
        cvv = String(fixedCvv).padStart(isAmex ? 4 : 3, '0').slice(0, isAmex ? 4 : 3);
    } else {
        const max = isAmex ? 9000 : 900;
        const min = isAmex ? 1000 : 100;
        cvv = String(Math.floor(Math.random() * (max - min + 1)) + min);
    }

    return { number, month, year, shortYear: year.slice(-2), cvv };
}

// ============================================================
//  FUNรโกรฦO PRINCIPAL: GERAR
