async function gerar() {
    const raw = binInput.value.trim();
    if (!raw) {
        alert('รขยโ Coloque pelo menos a Matriz (BIN).');
        return;
    }

    let qtd = parseInt(qtdInput.value) || 0;
    if (qtd < 1) {
        alert('รขยโ Informe uma quantidade vรยกlida (mรยญnimo 1).');
        return;
    }
    if (qtd > 1000) qtd = 1000;

    // Extrair BIN, mรยชs e ano se vierem no formato "BIN|MM|AAAA"
    let bin = raw;
    let fixedMonth = mesSelect.value || null;
    let fixedYear = anoSelect.value || null;

    if (raw.includes('|')) {
        const parts = raw.split('|');
        bin = parts[0].trim();
        if (parts[1] && parts[1].trim()) fixedMonth = parts[1].trim().padStart(2,'0');
        if (parts[2] && parts[2].trim()) {
            let y = parts[2].trim();
            if (y.length === 2) y = '20' + y;
            fixedYear = y;
        }
    }

    const cvvFixed = cvvInput.value.trim() || null;

    // Limpar bin para apenas nรยบmeros + x
    const cleanBin = bin.replace(/\s/g, '').toLowerCase();

    statusDiv.textContent = 'รขยยณ consultando BIN...';
    statusDiv.className = 'status';

    // Consultar API
    const binResult = await consultarBIN(cleanBin.replace(/x/g, '0').substring(0,6));

    // Exibir informaรยงรยตes
    if (binResult && binResult.success) {
        bankSpan.textContent = binResult.bank.toUpperCase() || '-';
        brandSpan.textContent = binResult.brand || '-';
        levelSpan.textContent = binResult.level.toUpperCase() || '-';
        const countryCode = binResult.country || '';
        countrySpan.textContent = countryCode.toUpperCase() || '-';
        flagEmoji.textContent = getCountryFlag(countryCode);
        binInfoDiv.classList.add('show');
        statusDiv.textContent = 'รขลโฆ BIN verificado';
        statusDiv.className = 'status finalizado';
    } else {
        bankSpan.textContent = 'N/A';
        brandSpan.textContent = 'N/A';
        levelSpan.textContent = 'N/A';
        countrySpan.textContent = 'N/A';
        flagEmoji.textContent = 'รฐลธยยณรฏยธย';
        binInfoDiv.classList.add('show');
        statusDiv.textContent = 'รขลกย รฏยธย API offline รขโฌโ usando fallback';
        statusDiv.className = 'status offline';
    }

    // Gerar cartรยตes
    let lista = '';
    for (let i = 0; i < qtd; i++) {
        const card = generateCompleteCard(cleanBin, fixedMonth, fixedYear, cvvFixed);
        // Formato: Nรยบmero|Mรยชs|Ano(4 dรยญgitos)|CVV
        lista += `${card.number}|${card.month}|${card.year}|${card.cvv}\n`;
    }

    resultadoText.value = lista.trim();
    contadorSpan.textContent = qtd;
    statusDiv.textContent = 'รขลโฆ finalizado รขลโรฏยธย';
    statusDiv.className = 'status finalizado';

    // Rolar para o textarea
    resultadoText.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ============================================================
//  COPIAR E BAIXAR
// ============================================================
function copiar() {
    const texto = resultadoText.value;
    if (!texto) { alert('Nada para copiar.'); return; }
    navigator.clipboard.writeText(texto).then(() => {
        alert('รฐลธโโน Copiado para a รยกrea de transferรยชncia!');
    }).catch(() => {
        resultadoText.select();
        document.execCommand('copy');
        alert('รฐลธโโน Copiado!');
    });
}

function baixar() {
    const texto = resultadoText.value;
    if (!texto) { alert('Nada para baixar.'); return; }
    const blob = new Blob([texto], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `cards_${new Date().toISOString().slice(0,10)}.txt`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
}

// ============================================================
//  ENTER PARA GERAR
// ============================================================
document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
        e.preventDefault();
        gerar();
    }
});

