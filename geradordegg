function getCountryFlag(countryCode) {
    if (!countryCode || countryCode.trim() === '') return 'รฐลธยยณรฏยธย';
    const three = countryCode.toUpperCase().substring(0,3);
    const two = countryMap[three] || '';
    return countryFlags[two] || 'รฐลธยยณรฏยธย';
}

// ============================================================
//  FUNรโกรฦO PARA CONSULTAR BIN VIA API REAL (FluidPay)
// ============================================================
async function consultarBIN(binNum) {
    try {
        const headers = {
            'Authorization': API_KEY,
            'Content-Type': 'application/json',
        };
        const data = {
            'type': 'tokenizer',
            'type_id': '230685b9-61e6-4dc4-8cb2-18ef6fd93146',
            'bin': binNum,
        };
        const response = await fetch(
            'https://app.fluidpay.com/api/lookup/bin/pub_2HT17PrC7sOCvNp1qwb9XBhb1RO',
            {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(data),
            }
        );
        const responseData = await response.json();

        if (responseData.status === 'success') {
            const d = responseData.data;
            return {
                success: true,
                bank: d.issuing_bank || 'Desconhecido',
                brand: d.card_brand || 'Desconhecido',
                level: d.card_level_generic || 'Desconhecido',
                country: d.country || '',
                type: d.card_type || 'CREDIT'
            };
        } else {
            // fallback local para BINs comuns (apenas BINs reais conhecidos)
            const fallback = getFallbackBINData(binNum);
            if (fallback) return { success: true, ...fallback };
            return { success: false };
        }
    } catch (error) {
        const fallback = getFallbackBINData(binNum);
        if (fallback) return { success: true, ...fallback };
        return { success: false };
    }
}

function getFallbackBINData(binNum) {
    const prefix = binNum.substring(0,6);
    const map = {
        '434769': { bank:'Banco do Brasil', brand:'VISA', level:'PLATINUM', country:'BRA', type:'CREDIT' },
        '516292': { bank:'Nubank', brand:'MASTERCARD', level:'STANDARD', country:'BRA', type:'CREDIT' },
        '453211': { bank:'Citibank', brand:'VISA', level:'GOLD', country:'USA', type:'CREDIT' },
